      "source": "import pandas as pd\nimport numpy as np\nfrom sklearn.preprocessing import StandardScaler\nfrom sklearn.neighbors import KNeighborsRegressor\nfrom sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score\nfrom sklearn.model_selection import train_test_split  # Temp use shuffle=False later\n\n# Load & prep (same as before)\ndf = pd.read_csv('Weather data.csv')\ndf = df.rename(columns={\n    'Date (Local Standard Time)': 'date',\n    'Air Temp. Inst. (∞C)': 'temp',\n    'Est. Dew Point Temp. (∞C)': 'dew',\n    'Humidity Inst. (%)': 'humidity',\n    'Wind Speed 10 m Syno. (km/h)': 'wind_speed',\n    'Wind Dir. 10 m Syno. (∞)': 'wind_dir',\n    'PM 2.5 Mass': 'pm25'\n})\ndf['date'] = pd.to_datetime(df['date'])\ndf = df.sort_values('date').reset_index(drop=True)\ndf = df.drop(columns=['Station Name'])\n\n# Impute & engineer (same)\nwind_median = df['wind_dir'].median()\ndf['wind_dir'] = df['wind_dir'].fillna(wind_median)\ndf['wind_sin'] = np.sin(2 * np.pi * df['wind_dir'] / 360)\ndf['wind_cos'] = np.cos(2 * np.pi * df['wind_dir'] / 360)\ndf['wind_speed_sq'] = df['wind_speed'] ** 2\ndf['hour'] = df['date'].dt.hour.astype(float)\ndf['dayofweek'] = df['date'].dt.dayofweek.astype(float)\ndf['month'] = df['date'].dt.month.astype(float)\ndf['temp_dew_diff'] = df['temp'] - df['dew']\n\n# Lags & rolls\nfor lag in [1, 3, 24]:\n    df[f'pm25_lag{lag}'] = df['pm25'].shift(lag)\nfor win in [3, 6, 24]:\n    df[f'pm25_roll_mean{win}'] = df['pm25'].rolling(window=win).mean()\n    df[f'temp_roll_mean{win}'] = df['temp'].rolling(window=win).mean()\n\n# CRITICAL: Drop pm25 NaNs FIRST, then fill remaining feature NaNs with forward-fill + mean\ndf = df.dropna(subset=['pm25'])\ndf = df.fillna(method='ffill').fillna(df.mean(numeric_only=True))  # Safe NaN fill\n\nprint(f\"Shape: {df.shape}\")\nprint(\"NaNs left:\", df.isnull().sum().sum())\n\n# Features\ntarget = 'pm25'\nfeature_cols = [col for col in df.columns if col != target and col != 'date']\nX = df[feature_cols].select_dtypes(include=[np.number])  # Numeric only\ny = df[target]\n\nprint(\"Features:\", list(X.columns))\nprint(\"X shape:\", X.shape)\n\n# Time-ordered split\nsplit_idx = int(0.8 * len(X))\nX_train, X_test = X.iloc[:split_idx], X.iloc[split_idx:]\ny_train, y_test = y.iloc[:split_idx], y.iloc[split_idx:]\n\n# Scale\nscaler = StandardScaler()\nX_train_scaled = scaler.fit_transform(X_train)\nX_test_scaled = scaler.transform(X_test)\n\n# Simple tuned KNN (no CV yet)\nknn = KNeighborsRegressor(n_neighbors=10, weights='distance')\nknn.fit(X_train_scaled, y_train)\ny_pred = knn.predict(X_test_scaled)\n\n# Evaluate\nr2 = r2_score(y_test, y_pred)\nrmse = np.sqrt(mean_squared_error(y_test, y_pred))\nmae = mean_absolute_error(y_test, y_pred)\nprint(f\"R2: {r2:.3f} (vs your 0.054)\")\nprint(f\"RMSE: {rmse:.3f}, MAE: {mae:.3f}\")\n\n# Save\ndf.to_csv('enhanced_pm25_data.csv', index=False)\n",
